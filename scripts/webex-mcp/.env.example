# Webex OAuth integration credentials.
# Create an integration at https://developer.webex.com/my-apps and fill in below.
# Copy this file to .env (same directory) and replace empty values.
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
WEBEX_REDIRECT_URI=http://localhost:8765/callback
WEBEX_SCOPES=spark:messages_read spark:rooms_read spark:memberships_read spark:people_read
